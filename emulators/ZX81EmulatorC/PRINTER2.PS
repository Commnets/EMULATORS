% =========================================================
% Page geometry helpers
% =========================================================

% pageWidth / pageHeight / pageTopY
% These are safe even if currentpagedevice is missing.
% Stack:
%   pageWidth  -> w
%   pageHeight -> h
%   pageTopY   -> topY (same as height in our translated space)
%
% In the fallback, we derive width/height from clippath pathbbox.
/pageWidth {
  /currentpagedevice where
  {
    pop currentpagedevice /PageSize get 0 get
  }
  {
    clippath pathbbox            % llx lly urx ury
    3 -1 roll sub                % (urx-llx) ury
    exch pop                     % -> width
  } ifelse
} def

/pageHeight {
  /currentpagedevice where
  {
    pop currentpagedevice /PageSize get 1 get
  }
  {
    clippath pathbbox            % llx lly urx ury
    exch sub                     % llx (ury-lly) urx
    2 -1 roll pop                % (ury-lly) urx
    exch pop                     % -> height
  } ifelse
} def

/pageTopY { pageHeight } def

% topLeftWithMargin
% Compute top-left point inside current clipping box (with margins).
% Stack:
%   marginX marginY -> x0 y0
/topLeftWithMargin {
  /mY exch def
  /mX exch def
  clippath pathbbox              % llx lly urx ury
  /uY exch def /uX exch def /lY exch def /lX exch def
  lX mX add                      % x0 = llx + mX
  uY mY sub                      % y0 = ury - mY
} def

% =========================================================
% Basic drawing routines
% =========================================================
/line { newpath moveto lineto stroke } bind def

/fillHole { newpath 0 360 arc fill } bind def

/fillCircle {
  /y exch def
  /x exch def
  gsave
    dotGray setgray
    newpath x y dotRadius 0 360 arc closepath fill
  grestore
} def

% =========================================================
% Decorative page drawing routines
% =========================================================

% drawBands
% Paints alternating tinted bands, aligned from the top edge.
% Requires:
%   PW, PH set
/drawBands {
  /bh cfg /bandHeight get def
  /tA cfg /bandTintA get def
  /tB cfg /bandTintB get def
  /tint getBandTint def

  % Base background fill
  gsave
    tint tB setTinted
    newpath 0 0 moveto PW 0 rlineto 0 PH rlineto
    PW neg 0 rlineto closepath fill
  grestore

  % Bands from the top: y is band-bottom in PS coords
  /y PH bh sub def
  /i 0 def
  {
    y 0 lt { exit } if
    gsave
      tint i 2 mod 0 eq { tA } { tB } ifelse setTinted
      newpath 0 y moveto
      PW 0 rlineto
      0 bh rlineto
      PW neg 0 rlineto
      closepath fill
    grestore
    /y y bh sub def
    /i i 1 add def
  } loop
} bind def

% drawRuling
% Draw horizontal ruled lines top-referenced, first always thin.
% Requires:
%   PW, PH set
/drawRuling {
  /cl cfg /contentLeft get def
  /cr cfg /contentRight get def
  /ct cfg /contentTop get def
  /cb cfg /contentBottom get def
  /tb cfg /tractorBand get def

  % Ruling spans between tractor bands (and respects content margins)
  /x1 cl tb add def
  /x2 PW cr sub tb sub def
  /pitch cfg /linePitch get def

  % yTop is "distance from top edge" (in points)
  /yTop ct def
  /k 1 def

  {
    yTop PH cb sub gt { exit } if
    /isMajor k cfg /majorEvery get mod 0 eq def

    % Convert top-referenced yTop to PostScript y coordinate
    /yPS PH yTop sub def

    gsave
      isMajor {
        cfg /majorLineGray get gray
        cfg /majorLineWidth get setlinewidth
      }{
        cfg /thinLineGray get gray
        cfg /thinLineWidth get setlinewidth
      } ifelse
      x1 yPS x2 yPS line
    grestore

    /yTop yTop pitch add def
    /k k 1 add def
  } loop
} bind def

% drawMicroCuts
% Draw horizontal dashed micro-cuts every foldEvery.
% Safe early return (NO 'exit' outside loops).
/drawMicroCuts {
  cfg /microCut get not { % disabled => do nothing
  }{
    /every cfg /foldEvery get def

    % Decide whether the line spans full width or only content area
    cfg /microCutAcrossTractor get
      { /x1 0 def /x2 PW def }
      {
        /cl cfg /contentLeft get def
        /cr cfg /contentRight get def
        /tb cfg /tractorBand get def
        /x1 cl tb add def
        /x2 PW cr sub tb sub def
      } ifelse

    /yTop 0 def
    {
      yTop PH gt { exit } if
      /yPS PH yTop sub def

      gsave
        cfg /microCutGray get gray
        cfg /microCutWidth get setlinewidth
        cfg /microCutDash get 0 setdash
        x1 yPS x2 yPS line
        [] 0 setdash
      grestore

      /yTop yTop every add def
    } loop
  } ifelse
} bind def

% drawMicroPerfs
% Draw vertical dashed micro-perforation lines at edges.
% Safe early return.
% Requires: PW, PH set
/drawMicroPerfs {
  cfg /microPerfs get not {
  }{
    /tb cfg /tractorBand get def
    /outer cfg /microPerfOuterInset get def
    /inner cfg /microPerfInnerInset get def

    /xL_outer outer def
    /xL_inner tb inner sub def
    /xR_outer PW outer sub def
    /xR_inner PW tb sub inner add def

    gsave
      cfg /microPerfGray get gray
      cfg /microPerfWidth get setlinewidth
      cfg /microPerfDash get 0 setdash

      xL_outer 0 xL_outer PH line
      xL_inner 0 xL_inner PH line
      xR_inner 0 xR_inner PH line
      xR_outer 0 xR_outer PH line

      [] 0 setdash
    grestore
  } ifelse
} bind def

% drawTractorHoles
% Draw white holes + gray stroke along both tractor bands.
% Requires: PW, PH set
/drawTractorHoles {
  /inset cfg /holeInset get def
  /r cfg /holeRadius get def
  /step 72 cfg /holesPerInch get div def

  /xL inset def
  /xR PW inset sub def

  /y r def
  /yMax PH r sub def

  {
    y yMax gt { exit } if

    % Hole fill (paper "cut-out")
    gsave
      1 gray
      xL y r fillHole
      xR y r fillHole
    grestore

    % Hole outline
    gsave
      cfg /holeGray get gray
      0.4 setlinewidth
      newpath xL y r 0 360 arc stroke
      newpath xR y r 0 360 arc stroke
    grestore

    /y y step add def
  } loop
} bind def

% drawFoldMarks
% Draw small marks at left/right edges every foldEvery.
% Safe early return.
% Requires: PW, PH set
/drawFoldMarks {
  cfg /foldMarks get not {
  }{
    /len cfg /foldMarkLen get def
    /every cfg /foldEvery get def
    /yTop 0 def

    gsave
      cfg /foldMarkGray get gray
      cfg /foldMarkWidth get setlinewidth
      {
        yTop PH gt { exit } if
        /yPS PH yTop sub def
        0 yPS 0 len add yPS line
        PW len sub yPS PW yPS line
        /yTop yTop every add def
      } loop
    grestore
  } ifelse
} bind def

% =========================================================
% Thermal Printer printer emulation (glyph rendering)
% =========================================================
/drawThermalDot {
    % stack: x y
    /ty exch def
    /tx exch def

    gsave
        tx ty translate

        % -------------------------------------------------
        % 1) outer thermical stain: big, lowm and wide
        % -------------------------------------------------
        0.42 setgray
        gsave
            1.55 0.62 scale
            newpath
            0.00 0.00 1.05 0 360 arc
            fill
        grestore

        % -------------------------------------------------
        % 2) lateral reinforcement for heat "drag out effect"
        %    horizontal continuity
        % -------------------------------------------------
        0.30 setgray
        gsave
            0.35 0.00 translate
            1.20 0.48 scale
            newpath
            0.00 0.00 0.95 0 360 arc
            fill
        grestore

        % -------------------------------------------------
        % 3) main core, darker, lightly not centered
        % -------------------------------------------------
        0.10 setgray
        gsave
            -0.08 0.03 translate
            1.05 0.42 scale
            newpath
            0.00 0.00 0.72 0 360 arc
            fill
        grestore

        % -------------------------------------------------
        % 4) second core to break out the simmetry
        % -------------------------------------------------
        0.18 setgray
        gsave
            0.28 -0.02 translate
            0.65 0.30 scale
            newpath
            0.00 0.00 0.70 0 360 arc
            fill
        grestore

    grestore
} bind def

% drawByteBits
% Render one byte as ONE HORIZONTAL ROW of 8 dots.
% Stack:
%   byte xLeft yTop -> -
% Bit mapping:
%   bit7 => leftmost dot at xLeft
%   bit0 => rightmost dot at xLeft + 7*dotStepX
/drawByteBits {
    % stack: byte x y
    /y0 exch def
    /x0 exch def
    /b  exch def

    0 1 7 {
        /i exch def
        /mask 1 7 i sub bitshift def
        b mask and 0 ne {
            x0 i dotStepX mul add
            y0
            drawThermalDot
        } if
    } for
} bind def

% drawByteArrayRows
% Draw n bytes as n stacked horizontal rows.
% Stack:
%   arr n xLeft yTop -> -
/drawByteArrayRows {
  10 dict begin
    /yTop exch def
    /xLeft exch def
    /n exch def
    /arr exch def

    0 1 n 1 sub {
      /k exch def
      arr k get
      xLeft
      yTop k dotStepY mul sub
      drawByteBits
    } for
  end
} def

% getGlyphRowBytesByCode
% Fetch glyph row bytes for code; fallback to code 0 if missing.
% Glyph data is assumed to be stored directly as 8 horizontal rows.
% Stack:
%   code -> glyphRows(8)
/getGlyphRowBytesByCode {
  /code exch def
  FontByCode code known
    { FontByCode code get }
    { FontByCode 0 get }
  ifelse
} def

% drawGlyphRows
% Draw one glyph described directly as row bytes.
% Stack:
%   glyphRows xLeft yTop -> -
/drawGlyphRows {
  10 dict begin
    /yTop exch def
    /xLeft exch def
    /glyphRows exch def

    glyphRows 8 xLeft yTop drawByteArrayRows
  end
} def

% drawCharByCode
% Draw a character (8x8) at xLeft,yTop assuming row-oriented glyph storage.
% Stack:
%   code xLeft yTop -> -
/drawCharByCode {
  10 dict begin
    /yTop exch def
    /xLeft exch def
    /code exch def

    code getGlyphRowBytesByCode
    xLeft yTop drawGlyphRows
  end
} def

% drawText
% Draw a string using 8x8 glyphs.
% Supports:
%   - space (32): advance only
%   - LF (10) or CR (13): newline
% Stack:
%   (text) xLeft yTop -> -
/drawText {
  20 dict begin
    /y0 exch def
    /x0 exch def
    /s exch def

    /cx x0 def
    /cy y0 def

    /advX dotStepX 8 mul charGapX add def
    /advY dotStepY 8 mul lineGapY add def

    0 1 s length 1 sub {
      /i exch def
      s i get /ch exch def

      ch 10 eq ch 13 eq or {
        /cx x0 def
        /cy cy advY sub def
      }{
        ch 32 eq {
          /cx cx advX add def
        }{
          ch cx cy drawCharByCode
          /cx cx advX add def
        } ifelse
      } ifelse
    } for
  end
} def

% drawByteBitsDouble
% Render one byte as a double-width horizontal row of 16 dots.
% Stack:
%   byte xLeft yTop -> -
/drawByteBitsDouble {
  10 dict begin
    /yTop exch def
    /xLeft exch def
    /b exch def

    0 1 7 {
      /i exch def
      b 1 7 i sub bitshift and 0 ne {
        xLeft i 2 mul dotStepX mul add yTop fillCircle
        xLeft i 2 mul 1 add dotStepX mul add yTop fillCircle
      } if
    } for
  end
} def

% drawByteArrayRowsDouble
% Draw n bytes as n stacked horizontal rows, double width.
% Stack:
%   arr n xLeft yTop -> -
/drawByteArrayRowsDouble {
  10 dict begin
    /yTop exch def
    /xLeft exch def
    /n exch def
    /arr exch def

    0 1 n 1 sub {
      /k exch def
      arr k get
      xLeft
      yTop k dotStepY mul sub
      drawByteBitsDouble
    } for
  end
} def

% drawGlyphRowsDouble
% Draw one row-oriented glyph in DOUBLE WIDTH => 16 columns.
% Stack:
%   glyphRows xLeft yTop -> -
/drawGlyphRowsDouble {
  10 dict begin
    /yTop exch def
    /xLeft exch def
    /glyphRows exch def

    glyphRows 8 xLeft yTop drawByteArrayRowsDouble
  end
} def

% drawCharByCodeDouble
% Render one 8x8 glyph in DOUBLE WIDTH => 16 columns,
% assuming row-oriented glyph storage.
/drawCharByCodeDouble {
  10 dict begin
    /yTop exch def
    /xLeft exch def
    /code exch def

    code getGlyphRowBytesByCode
    xLeft yTop drawGlyphRowsDouble
  end
} def


% Compatibility aliases (legacy names)
/drawByteArrayColumns { drawByteArrayRows } bind def
/getGlyphRowsByCode { getGlyphRowBytesByCode } bind def
/drawByteArrayColumnsDouble { drawByteArrayRowsDouble } bind def

% drawTextDouble
% Double-width text rendering (each glyph becomes 16 columns).
% Supports:
%   - space (32)
%   - LF (10) / CR (13)
% Stack:
%   (text) xLeft yTop -> -
/drawTextDouble {
  20 dict begin
    /y0 exch def
    /x0 exch def
    /s exch def

    /cx x0 def
    /cy y0 def

    /advX dotStepX 16 mul charGapX add def
    /advY dotStepY 8 mul lineGapY add def

    0 1 s length 1 sub {
      /i exch def
      s i get /ch exch def

      ch 10 eq ch 13 eq or {
        /cx x0 def
        /cy cy advY sub def
      }{
        ch 32 eq {
          /cx cx advX add def
        }{
          ch cx cy drawCharByCodeDouble
          /cx cx advX add def
        } ifelse
      } ifelse
    } for
  end
} def
% Page setup and rendering helpers
% =========================================================

% setupPage
% - Applies PageSize from cfg
% - Normalizes coordinate system so clip ll corner is (0,0)
% - Defines PW and PH
% - Clips to the page rectangle
/setupPage {
  % Request physical PageSize
  /reqPW cfg /pageWidthInch get inch def
  /reqPH cfg /pageHeightInch get inch def
  << /PageSize [reqPW reqPH] >> setpagedevice

  initgraphics
  erasepage

  % Capture clipping bounding box (in device space)
  clippath pathbbox               % llx lly urx ury
  /ury exch def /urx exch def
  /lly exch def /llx exch def

  % Translate so ll becomes (0,0)
  llx neg lly neg translate

  % Compute page width/height in this normalized space
  /PW urx llx sub def
  /PH ury lly sub def

  % Force clip to exact page rectangle
  newpath 0 0 moveto PW 0 rlineto 0 PH rlineto
  PW neg 0 rlineto closepath clip newpath
} bind def

% drawPaper
% Draws all mechanical/page decorations based on cfg.
/drawPaper {
  gsave
    drawBands
    drawRuling
    drawMicroCuts
    drawMicroPerfs
    drawTractorHoles
    drawFoldMarks
  grestore
} bind def

% =========================================================
% MAIN PROGRAM
% =========================================================
% ----Page:00----------------------------------------------
setupPage
drawPaper

initgraphics
0 0 topLeftWithMargin /y0 exch def /x0 exch def
gsave
0.5142857 0.75 scale
/x0 x0 1.9444444 mul def
/y0 y0 1.3333333 mul def

