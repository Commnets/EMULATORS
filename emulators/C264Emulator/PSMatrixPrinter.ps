initgraphics

% =========================================================
% Global Parameters
% =========================================================
/dotRadius  1 def        % point radix
/dotGray    0.15 def     % point gray level

% Steps center to center (column & row)
/dotStepX   2 def        % distance between columns (centers)
/dotStepY   2 def        % distance between vertical points (centers)

% Distance between letters and lines (additional in points)
/charGapX   0 def
/lineGapY   1 def

% =========================================================
% Routine: fillCircle
% x y -> -
% =========================================================
/fillCircle {
  /y exch def
  /x exch def
  gsave
    dotGray setgray
    newpath x y dotRadius 0 360 arc closepath fill
  grestore
} def

% =========================================================
% Routine: drawByteBits (COLUMNA)
% byte xStart yStart -> -
% bit0 = up pixel (yStart), bit7 = low pixel
% =========================================================
/drawByteBits {
  10 dict begin
    /yStart exch def
    /xStart exch def
    /b exch def

    0 1 7 {
      /i exch def
      b 1 i bitshift and 0 ne {
        xStart
        yStart i dotStepY mul sub
        fillCircle
      } if
    } for
  end
} def

% =========================================================
% Routine: drawByteArrayColumns
% arr n xBase yTop -> -
% Draw n bytes like n joined columns.
% =========================================================
/drawByteArrayColumns {
  10 dict begin
    /yTop exch def
    /xBase exch def
    /n exch def
    /arr exch def

    0 1 n 1 sub {
      /k exch def
      arr k get
      xBase k dotStepX mul add
      yTop
      drawByteBits
    } for
  end
} def

% =========================================================
% Routine: getGlyphColsByCode
% code -> -
% Look for glifo; if it doesn't exist /0 is used.
% =========================================================
/getGlyphColsByCode { % asciiCode -> glyphArray(8)
  /code exch def
  Font8x8ByCode code known
    { Font8x8ByCode code get }
    { Font8x8ByCode 0 get }   % Unknown
  ifelse
} def

% =========================================================
% Routine: drawCharByCode
% asciiCode xLeft yTop -> -
% Look for glifo; if it doesn't exist 0 is used.
% Then call drawByteArrayColumns(glifo, 8, xLeft, yTop).
% =========================================================
/drawCharByCode {
  10 dict begin
    /yTop exch def
    /xLeft exch def
    /code exch def
    code getGlyphColsByCode
    8 xLeft yTop drawByteArrayColumns
  end
} def

% =========================================================
% Routine: drawText
% (text) xLeft yTop -> -
% Iterates a string and draws only alphanum characters, the res = /Unknown.
% Supports:
% - space (32): move forward with no drawing
% - line jump (10): move down to the next line
% =========================================================
/drawText {
  20 dict begin
    /y0 exch def
    /x0 exch def
    /s exch def

    /cx x0 def
    /cy y0 def

    % Avances
    /advX dotStepX 8 mul charGapX add def
    /advY dotStepY 8 mul lineGapY add def

    0 1 s length 1 sub {
      /i exch def
      s i get /ch exch def

      ch 10 eq ch 13 eq or {          % LF o CR
        /cx x0 def
        /cy cy advY sub def
      }{
        ch 32 eq {                    % space
          /cx cx advX add def
        }{
          ch cx cy drawCharByCode
          /cx cx advX add def
        } ifelse
      } ifelse
    } for
  end
} def

% =========================================================
% drawByteArrayColumnsDouble
% arr n xBase yTop -> -
% Iterates arr[0..n-1] and per each byte draws 2 columns:
% col 2*k and col 2*k+1 with the same byte.
% outcome: n bytes -> 2*n columsn (8 -> 16)
% =========================================================
/drawByteArrayColumnsDouble {
  10 dict begin
    /yTop exch def
    /xBase exch def
    /n exch def
    /arr exch def

    0 1 n 1 sub {
      /k exch def
      /b arr k get def

      % First column (2*k)
      b
      xBase k 2 mul dotStepX mul add
      yTop
      drawByteBits

      % Second column (2*k+1)
      b
      xBase k 2 mul 1 add dotStepX mul add
      yTop
      drawByteBits
    } for
  end
} def

% =========================================================
% drawCharByCodeDouble
% asciiCode xLeft yTop -> -
% Look for glifo in Font8x8V and draws it double space
% =========================================================
/drawCharByCodeDouble {
  10 dict begin
    /yTop exch def
    /xLeft exch def
    /code exch def
    code getGlyphColsByCode
    8 xLeft yTop drawByteArrayColumnsDouble
  end
} def

% =========================================================
% drawTextDouble
% (text) xLeft yTop -> -
% Iterates a string an print each leatter out with double width.
% Supports:
% - space (32): move forward with no drawing
% - line jumo (10): move to the next line
% =========================================================
/drawTextDouble {
  20 dict begin
    /y0 exch def
    /x0 exch def
    /s exch def

    /cx x0 def
    /cy y0 def

    % Avances: 16 columnas (doble ancho) + gap
    /advX dotStepX 16 mul charGapX add def
    /advY dotStepY 8 mul  lineGapY add def

    0 1 s length 1 sub {
      /i exch def
      s i get /ch exch def

      ch 10 eq ch 13 eq or {          % LF o CR
        /cx x0 def
        /cy cy advY sub def
      }{
        ch 32 eq {                    % espacio
          /cx cx advX add def
        }{
          ch cx cy drawCharByCodeDouble
          /cx cx advX add def
        } ifelse
      } ifelse
    } for
  end
} def
