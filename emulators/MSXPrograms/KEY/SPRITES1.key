10 REM MSX BASIC 1.0 - SPRITE GRANDE 16x16 (2x2 SPRITES 8x8)
20 SCREEN 1: COLOR 15,4,4: CLS
30 SPRITE ON
40 REM PATRON 0 (ARRIBA-IZQUIERDA): BLOQUE SOLIDO "REDONDEADO"
50 SPRITE$(0)=CHR$(60)+CHR$(126)+CHR$(255)+CHR$(255)+CHR$(255)+CHR$(255)+CHR$(126)+CHR$(60)
60 REM PATRON 1 (ARRIBA-DERECHA)
70 SPRITE$(1)=CHR$(60)+CHR$(126)+CHR$(255)+CHR$(255)+CHR$(255)+CHR$(255)+CHR$(126)+CHR$(60)
80 REM PATRON 2 (ABAJO-IZQUIERDA)
90 SPRITE$(2)=CHR$(60)+CHR$(126)+CHR$(255)+CHR$(255)+CHR$(255)+CHR$(255)+CHR$(126)+CHR$(60)
100 REM PATRON 3 (ABAJO-DERECHA)
110 SPRITE$(3)=CHR$(60)+CHR$(126)+CHR$(255)+CHR$(255)+CHR$(255)+CHR$(255)+CHR$(126)+CHR$(60)
120 X=120: Y=80
130 C=15: REM COLOR BLANCO
140 REM 4 SPRITES 8x8 FORMANDO 16x16
150 PUT SPRITE 0,(X,  Y),C,0
160 PUT SPRITE 1,(X+8,Y),C,1
170 PUT SPRITE 2,(X,  Y+8),C,2
180 PUT SPRITE 3,(X+8,Y+8),C,3
190 REM CAMBIO DE COLOR (EJEMPLO): PULSA TECLA PARA CAMBIAR
200 A$=INKEY$: IF A$="" THEN 200
210 C=6: REM ROJO
220 PUT SPRITE 0,(X,  Y),C,0
230 PUT SPRITE 1,(X+8,Y),C,1
240 PUT SPRITE 2,(X,  Y+8),C,2
250 PUT SPRITE 3,(X+8,Y+8),C,3
260 REM ESPERAR PARA SALIR
270 A$=INKEY$: IF A$="" THEN 270
280 END
