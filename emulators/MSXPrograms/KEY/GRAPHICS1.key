10 REM ELIPSES ORBITANDO - MSX BASIC 1.0 - SCREEN 2 (ALTA RESOLUCION)
20 DEFINT A-Z
30 PI=4*ATN(1)
40 SCREEN 2: COLOR 15,1,1: CLS
50 REM CENTRO DE LA ORBITA
60 CX=128: CY=96
70 REM PARAMETROS GENERALES
80 N=8:REM NUMERO DE ELIPSES
90 STEPANG=PI/48:REM VELOCIDAD DE ROTACION
100 T=0
110 REM BUCLE PRINCIPAL
120 CLS
130 REM PUNTO CENTRAL
140 PSET (CX,CY),15
150 FOR I=0 TO N-1
160 REM ANGULO DE ORBITA
170 A=T+I*(2*PI/N)
180 REM RADIO DE LA ORBITA
190 RO=20+I*7
200 REM POSICION DEL CENTRO DE LA ELIPSE
210 EX=CX+INT(RO*COS(A))
220 EY=CY+INT(RO*SIN(A))
230 REM RADIO BASE DE LA ELIPSE
240 R=10+I*2
250 REM ASPECTO (DEFORMACION A ELIPSE)
260 ASP=0.3+0.6*(0.5+0.5*SIN(T*2+I))
270 REM COLOR (1..15)
280 COL=(I MOD 15)+1
290 REM DIBUJAR ELIPSE
300 CIRCLE (EX,EY),R,COL,,,ASP
310 NEXT I
320 REM AVANZAR TIEMPO
330 T=T+STEPANG
340 REM SALIR CON TECLA
350 A$=INKEY$: IF A$<>"" THEN END
360 GOTO 120
