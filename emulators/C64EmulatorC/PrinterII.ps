% ============================================================
% Basic Elements to manage the page configuration
% And basic methods to draw the elements of the page
% ============================================================
/inch { 72 mul } bind def          % Convert inches to PostScript points
/gray { setgray } bind def         % Grayscale shortcut
/rgb  { setrgbcolor } bind def     % RGB shortcut

/line { newpath moveto lineto stroke } bind def
/fillCircle { newpath 0 360 arc fill } bind def

% ============================================================
% Color palettes to draw the bands in the page (selectable tone system)
% And method to retrive the right value of the selected tint
% ============================================================
/BandPalettes <<
  /Blue    [0.82 0.90 1.00]
  /Green   [0.86 1.00 0.90]
  /Gray    [0.92 0.92 0.92]
  /Ivory   [1.00 0.99 0.94]
  /Pink    [1.00 0.90 0.94]
>> def

% ------------------------------------------------------------
% Blend between white and a tint color
% Input:
%   [r g b] t
%   t = 0  -> pure white
%   t = 1  -> pure tint
% ------------------------------------------------------------
/setTinted {
  /t exch def
  aload pop /b exch def /g exch def /r exch def
  1 r sub t mul 1 exch sub
  1 g sub t mul 1 exch sub
  1 b sub t mul 1 exch sub
  setrgbcolor
} bind def

% Retrieve tint from selected palette.
% If palette does not exist, fallback to manual RGB definition.
/getBandTint {
  cfg /bandTone known {
    BandPalettes cfg /bandTone get known {
      BandPalettes cfg /bandTone get get
    }{
      cfg /bandTint get
    } ifelse
  }{
    cfg /bandTint get
  } ifelse
} bind def

% ============================================================
% Configuration of the page
% All parameters centralized here
% ============================================================
/cfg <<
  % ------------------------
  % Physical page size (inches)
  % ------------------------
  /pageWidthInch   9.5
  /pageHeightInch  11

  % ------------------------
  % Content margins (mechanical elements reach edges)
  % ------------------------
  /contentLeft     0.1 inch
  /contentRight    0.1 inch
  /contentTop      0 inch
  /contentBottom   0 inch

  % ------------------------
  % Tractor band width (each side)
  % ------------------------
  /tractorBand     0.5 inch

  % ------------------------
  % Horizontal ruling configuration
  % ------------------------
  /linePitch       1 6 div inch     % 6 lines per inch
  /thinLineGray    0.85
  /thinLineWidth   0.4
  /majorEvery      6                % Every 6th line is major
  /majorLineGray   0.65
  /majorLineWidth  0.7

  % ------------------------
  % Alternating background bands
  % ------------------------
  /bandTone        /Green
  /bandTint        [0.82 0.90 1.00]
  /bandTintA       0.18
  /bandTintB       0.10
  /bandHeight      0.5 inch
  /bandsFromTop    true

  % ------------------------
  % Tractor feed holes
  % ------------------------
  /holesPerInch    2
  /holeRadius      0.06 inch
  /holeInset       0.25 inch
  /holeGray        0.60

  % ------------------------
  % Vertical micro-perforation lines
  % ------------------------
  /microPerfs      true
  /microPerfGray   0.55
  /microPerfWidth  0.6
  /microPerfDash   [1.2 3.0]
  /microPerfOuterInset  0.10 inch
  /microPerfInnerInset  0.08 inch

  % ------------------------
  % Horizontal micro-cut (sheet separation)
  % ------------------------
  /microCut        true
  /foldEvery       3 inch
  /microCutGray    0.55
  /microCutWidth   0.7
  /microCutDash    [2.0 2.5]
  /microCutAcrossTractor true

  % ------------------------
  % Optional fold marks
  % ------------------------
  /foldMarks       true
  /foldMarkGray    0.50
  /foldMarkWidth   0.8
  /foldMarkLen     0.3 inch
>> def

% =========================
% Page geometry helpers
% =========================
/pageWidth {
  /currentpagedevice where
  {
    pop currentpagedevice /PageSize get 0 get
  }
  {
    clippath pathbbox            % llx lly urx ury
    3 -1 roll pop                % drop llx
    exch pop                     % drop lly
    % stack now: urx ury -> keep urx as width reference? (not width)
    % For width, easier:
  } ifelse
} def

/pageHeight {
  /currentpagedevice where
  {
    pop currentpagedevice /PageSize get 1 get
  }
  {
    clippath pathbbox            % llx lly urx ury
    3 -1 roll pop                % drop llx
    2 -1 roll pop                % drop lly
    exch pop                     % drop urx
    % stack now: ury
  } ifelse
} def

/pageTopY {
  /currentpagedevice where
  {
    pop currentpagedevice /PageSize get 1 get
  }
  {
    clippath pathbbox            % llx lly urx ury
    3 -1 roll pop                % drop llx
    2 -1 roll pop                % drop lly
    exch pop                     % drop urx
    % stack now: ury
  } ifelse
} def

% =========================
% Top-left of the *clipping* area, with margins
% =========================
/topLeftWithMargin {  % marginX marginY -> x0 y0
  /mY exch def
  /mX exch def
  clippath pathbbox          % llx lly urx ury
  /uY exch def /uX exch def /lY exch def /lX exch def
  lX mX add                  % x0
  uY mY sub                  % y0
} def


% =========================================================
% Global Parameters
% =========================================================
/dotRadius  1 def        % point radix
/dotGray    0.15 def     % point gray level

% Steps center to center (column & row)
/dotStepX   2 def        % distance between columns (centers)
/dotStepY   2 def        % distance between vertical points (centers)

% Distance between letters and lines (additional in points)
/charGapX   0 def
/lineGapY   1 def

% =========================================================
% Routine: fillCircle
% x y -> -
% =========================================================
/fillCircle {
  /y exch def
  /x exch def
  gsave
    dotGray setgray
    newpath x y dotRadius 0 360 arc closepath fill
  grestore
} def

% =========================================================
% Routine: drawByteBits (COLUMNA)
% byte xStart yStart -> -
% bit0 = up pixel (yStart), bit6 = low pixel
% =========================================================
/drawByteBits {
  10 dict begin
    /yStart exch def
    /xStart exch def
    /b exch def

    0 1 6 {
      /i exch def
      b 1 i bitshift and 0 ne {
        xStart
        yStart i dotStepY mul sub
        fillCircle
      } if
    } for
  end
} def

% =========================================================
% Routine: drawByteArrayColumns
% arr n xBase yTop -> -
% Draw n bytes like n joined columns.
% =========================================================
/drawByteArrayColumns {
  10 dict begin
    /yTop exch def
    /xBase exch def
    /n exch def
    /arr exch def

    0 1 n 1 sub {
      /k exch def
      arr k get
      xBase k dotStepX mul add
      yTop
      drawByteBits
    } for
  end
} def

% =========================================================
% Routine: getGlyphColsByCode
% code -> -
% Look for glifo; if it doesn't exist /0 is used.
% =========================================================
/getGlyphColsByCode { % asciiCode -> glyphArray(8)
  /code exch def
  FontByCode code known
    { FontByCode code get }
    { FontByCode 0 get }   % Unknown
  ifelse
} def

% =========================================================
% Routine: drawCharByCode
% asciiCode xLeft yTop -> -
% Look for glifo; if it doesn't exist 0 is used.
% Then call drawByteArrayColumns(glifo, 8, xLeft, yTop).
% =========================================================
/drawCharByCode {
  10 dict begin
    /yTop exch def
    /xLeft exch def
    /code exch def
    code getGlyphColsByCode
    6 xLeft yTop drawByteArrayColumns
  end
} def

% =========================================================
% Routine: drawText
% (text) xLeft yTop -> -
% Iterates a string and draws only alphanum characters, the res = /Unknown.
% Supports:
% - space (32): move forward with no drawing
% - line jump (10): move down to the next line
% =========================================================
/drawText {
  20 dict begin
    /y0 exch def
    /x0 exch def
    /s exch def

    /cx x0 def
    /cy y0 def

    % Avances
    /advX dotStepX 6 mul charGapX add def
    /advY dotStepY 8 mul lineGapY add def

    0 1 s length 1 sub {
      /i exch def
      s i get /ch exch def

      ch 10 eq ch 13 eq or {          % LF o CR
        /cx x0 def
        /cy cy advY sub def
      }{
        ch 32 eq {                    % space
          /cx cx advX add def
        }{
          ch cx cy drawCharByCode
          /cx cx advX add def
        } ifelse
      } ifelse
    } for
  end
} def

% =========================================================
% drawByteArrayColumnsDouble
% arr n xBase yTop -> -
% Iterates arr[0..n-1] and per each byte draws 2 columns:
% col 2*k and col 2*k+1 with the same byte.
% outcome: n bytes -> 2*n columsn (8 -> 16)
% =========================================================
/drawByteArrayColumnsDouble {
  10 dict begin
    /yTop exch def
    /xBase exch def
    /n exch def
    /arr exch def

    0 1 n 1 sub {
      /k exch def
      /b arr k get def

      % First column (2*k)
      b
      xBase k 2 mul dotStepX mul add
      yTop
      drawByteBits

      % Second column (2*k+1)
      b
      xBase k 2 mul 1 add dotStepX mul add
      yTop
      drawByteBits
    } for
  end
} def

% =========================================================
% drawCharByCodeDouble
% asciiCode xLeft yTop -> -
% Look for glifo in Font8x8V and draws it double space
% =========================================================
/drawCharByCodeDouble {
  10 dict begin
    /yTop exch def
    /xLeft exch def
    /code exch def
    code getGlyphColsByCode
    6 xLeft yTop drawByteArrayColumnsDouble
  end
} def

% =========================================================
% drawTextDouble
% (text) xLeft yTop -> -
% Iterates a string an print each leatter out with double width.
% Supports:
% - space (32): move forward with no drawing
% - line jumo (10): move to the next line
% =========================================================
/drawTextDouble {
  20 dict begin
    /y0 exch def
    /x0 exch def
    /s exch def

    /cx x0 def
    /cy y0 def

    % Avances: 16 columnas (doble ancho) + gap
    /advX dotStepX 12 mul charGapX add def
    /advY dotStepY 8 mul  lineGapY add def

    0 1 s length 1 sub {
      /i exch def
      s i get /ch exch def

      ch 10 eq ch 13 eq or {          % LF o CR
        /cx x0 def
        /cy cy advY sub def
      }{
        ch 32 eq {                    % espacio
          /cx cx advX add def
        }{
          ch cx cy drawCharByCodeDouble
          /cx cx advX add def
        } ifelse
      } ifelse
    } for
  end
} def


% ============================================================
% Drawing procedures
% ============================================================

% ------------------------------------------------------------
% Draw alternating tinted bands (aligned from top)
% ------------------------------------------------------------
/drawBands {
  /bh cfg /bandHeight get def
  /tA cfg /bandTintA get def
  /tB cfg /bandTintB get def
  /tint getBandTint def

  % Base background fill
  gsave
    tint tB setTinted
    newpath 0 0 moveto PW 0 rlineto 0 PH rlineto
    PW neg 0 rlineto closepath fill
  grestore

  % Start from top edge
  /y PH bh sub def
  /i 0 def
  {
    y 0 lt { exit } if
    gsave
      tint i 2 mod 0 eq { tA } { tB } ifelse setTinted
      newpath
        0 y moveto
        PW 0 rlineto
        0 bh rlineto
        PW neg 0 rlineto
      closepath fill
    grestore
    /y y bh sub def
    /i i 1 add def
  } loop
} bind def

% ------------------------------------------------------------
% Draw horizontal ruling (top-referenced)
% First line always thin
% ------------------------------------------------------------
/drawRuling {

  /cl cfg /contentLeft get def
  /cr cfg /contentRight get def
  /ct cfg /contentTop get def
  /cb cfg /contentBottom get def
  /tb cfg /tractorBand get def

  /x1 cl tb add def
  /x2 PW cr sub tb sub def
  /pitch cfg /linePitch get def

  /yTop ct def
  /k 1 def

  {
    yTop PH cb sub gt { exit } if
    /isMajor k cfg /majorEvery get mod 0 eq def
    /yPS PH yTop sub def

    gsave
      isMajor {
        cfg /majorLineGray get gray
        cfg /majorLineWidth get setlinewidth
      }{
        cfg /thinLineGray get gray
        cfg /thinLineWidth get setlinewidth
      } ifelse
      x1 yPS x2 yPS line
    grestore

    /yTop yTop pitch add def
    /k k 1 add def
  } loop
} bind def

% ------------------------------------------------------------
% Draw horizontal micro-cut lines
% ------------------------------------------------------------
/drawMicroCuts {
  cfg /microCut get not { exit } if

  /every cfg /foldEvery get def
  cfg /microCutAcrossTractor get
    { /x1 0 def /x2 PW def }
    {
      /cl cfg /contentLeft get def
      /cr cfg /contentRight get def
      /tb cfg /tractorBand get def
      /x1 cl tb add def
      /x2 PW cr sub tb sub def
    } ifelse

  /yTop 0 def
  {
    yTop PH gt { exit } if
    /yPS PH yTop sub def

    gsave
      cfg /microCutGray get gray
      cfg /microCutWidth get setlinewidth
      cfg /microCutDash get 0 setdash
      x1 yPS x2 yPS line
      [] 0 setdash
    grestore

    /yTop yTop every add def
  } loop
} bind def

% ------------------------------------------------------------
% Draw vertical micro-perforation lines (edge-based)
% ------------------------------------------------------------
/drawMicroPerfs {
  cfg /microPerfs get not { exit } if

  /tb cfg /tractorBand get def
  /outer cfg /microPerfOuterInset get def
  /inner cfg /microPerfInnerInset get def

  /xL_outer outer def
  /xL_inner tb inner sub def
  /xR_outer PW outer sub def
  /xR_inner PW tb sub inner add def

  gsave
    cfg /microPerfGray get gray
    cfg /microPerfWidth get setlinewidth
    cfg /microPerfDash get 0 setdash

    xL_outer 0 xL_outer PH line
    xL_inner 0 xL_inner PH line
    xR_inner 0 xR_inner PH line
    xR_outer 0 xR_outer PH line

    [] 0 setdash
  grestore
} bind def

% ------------------------------------------------------------
% Draw tractor feed holes
% ------------------------------------------------------------
/drawTractorHoles {
  /inset cfg /holeInset get def
  /r cfg /holeRadius get def
  /step 72 cfg /holesPerInch get div def

  /xL inset def
  /xR PW inset sub def

  /y r def
  /yMax PH r sub def

  {
    y yMax gt { exit } if

    gsave
      1 gray
      xL y r fillCircle
      xR y r fillCircle
    grestore

    gsave
      cfg /holeGray get gray
      0.4 setlinewidth
      newpath xL y r 0 360 arc stroke
      newpath xR y r 0 360 arc stroke
    grestore

    /y y step add def
  } loop
} bind def

% ------------------------------------------------------------
% Draw optional fold marks
% ------------------------------------------------------------
/drawFoldMarks {
  cfg /foldMarks get not { exit } if

  /len cfg /foldMarkLen get def
  /every cfg /foldEvery get def
  /yTop 0 def

  gsave
    cfg /foldMarkGray get gray
    cfg /foldMarkWidth get setlinewidth
    {
      yTop PH gt { exit } if
      /yPS PH yTop sub def
      0 yPS 0 len add yPS line
      PW len sub yPS PW yPS line
      /yTop yTop every add def
    } loop
  grestore
} bind def

/reqPW cfg /pageWidthInch get inch def
/reqPH cfg /pageHeightInch get inch def
<< /PageSize [reqPW reqPH] >> setpagedevice


initgraphics

% Align origin with actual device clipping area
clippath pathbbox
/ury exch def /urx exch def
/lly exch def /llx exch def
llx neg lly neg translate

/PW urx llx sub def
/PH ury lly sub def

% Explicit clipping region
newpath 0 0 moveto PW 0 rlineto 0 PH rlineto
PW neg 0 rlineto closepath clip newpath

gsave
  drawBands
  drawRuling
  drawMicroCuts
  drawMicroPerfs
  drawTractorHoles
  drawFoldMarks
grestore


36 0 topLeftWithMargin /y0 exch def /x0 exch def

