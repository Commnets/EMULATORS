100OPEN4,4:CMD4
110SO$=CHR$(14):SI$=CHR$(15)
115PO$=CHR$(16):ESC$=CHR$(27)
120CN=23:AM=16:OF=4
130A$="-":FORI=0TOCN+AM:A$=A$+"-":NEXT
140SP$="       "
150PRINTSO$"      SIN CURVE"
160PRINTSI$
170PRINTLEFT$(SP$,OF-1)+"X"
180PRINTSPC(CN-AM-OF-1)+"-1";
190PRINTSPC(AM-1)"0"
200PRINTSPC(AM-1)"1"
210PRINTA$
220FORI=0TO360STEP10
230I$=RIGHT$(SP$+STR$(I),OF)
240Y0=CN*6+AM*6*SIN(I*3.14/180)
250YH=INT(Y0/256):YL=Y0-YH*256
270PRINTI$ESC$PO$CHR$(YH)CHR$(YL)"*"
280NEXT
290PRINT#4:CLOSE4
