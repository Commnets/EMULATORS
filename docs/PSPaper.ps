%!PS-Adobe-3.0
%%Title: Dot-Matrix Paper (Edges + Top-aligned Bands + Color Tones) - SINGLE PAGE
%%Pages: 1
%%EndComments

%%BeginProlog
% ============================================================
% Units and basic utility procedures
% ============================================================

/inch { 72 mul } bind def          % Convert inches to PostScript points
/gray { setgray } bind def         % Grayscale shortcut
/rgb  { setrgbcolor } bind def     % RGB shortcut

/line { newpath moveto lineto stroke } bind def
/fillCircle { newpath 0 360 arc fill } bind def

% ------------------------------------------------------------
% Blend between white and a tint color
% Input:
%   [r g b] t
%   t = 0  -> pure white
%   t = 1  -> pure tint
% ------------------------------------------------------------
/setTinted {
  /t exch def
  aload pop /b exch def /g exch def /r exch def
  1 r sub t mul 1 exch sub
  1 g sub t mul 1 exch sub
  1 b sub t mul 1 exch sub
  setrgbcolor
} bind def

% ============================================================
% Color palettes (selectable tone system)
% ============================================================

/BandPalettes <<
  /Blue    [0.82 0.90 1.00]
  /Green   [0.86 1.00 0.90]
  /Gray    [0.92 0.92 0.92]
  /Ivory   [1.00 0.99 0.94]
  /Pink    [1.00 0.90 0.94]
>> def

% Retrieve tint from selected palette.
% If palette does not exist, fallback to manual RGB definition.
/getBandTint {
  cfg /bandTone known {
    BandPalettes cfg /bandTone get known {
      BandPalettes cfg /bandTone get get
    }{
      cfg /bandTint get
    } ifelse
  }{
    cfg /bandTint get
  } ifelse
} bind def

% ============================================================
% Configuration dictionary
% All parameters centralized here
% ============================================================

/cfg <<
  % ------------------------
  % Physical page size (inches)
  % ------------------------
  /pageWidthInch   9.5
  /pageHeightInch  11

  % ------------------------
  % Content margins (mechanical elements reach edges)
  % ------------------------
  /contentLeft     0.1 inch
  /contentRight    0.1 inch
  /contentTop      0 inch
  /contentBottom   0 inch

  % ------------------------
  % Tractor band width (each side)
  % ------------------------
  /tractorBand     0.5 inch

  % ------------------------
  % Horizontal ruling configuration
  % ------------------------
  /linePitch       1 6 div inch     % 6 lines per inch
  /thinLineGray    0.85
  /thinLineWidth   0.4
  /majorEvery      6                % Every 6th line is major
  /majorLineGray   0.65
  /majorLineWidth  0.7

  % ------------------------
  % Alternating background bands
  % ------------------------
  /bandTone        /Green
  /bandTint        [0.82 0.90 1.00]
  /bandTintA       0.18
  /bandTintB       0.10
  /bandHeight      0.5 inch
  /bandsFromTop    true

  % ------------------------
  % Tractor feed holes
  % ------------------------
  /holesPerInch    2
  /holeRadius      0.06 inch
  /holeInset       0.25 inch
  /holeGray        0.60

  % ------------------------
  % Vertical micro-perforation lines
  % ------------------------
  /microPerfs      true
  /microPerfGray   0.55
  /microPerfWidth  0.6
  /microPerfDash   [1.2 3.0]
  /microPerfOuterInset  0.10 inch
  /microPerfInnerInset  0.08 inch

  % ------------------------
  % Horizontal micro-cut (sheet separation)
  % ------------------------
  /microCut        true
  /foldEvery       3 inch
  /microCutGray    0.55
  /microCutWidth   0.7
  /microCutDash    [2.0 2.5]
  /microCutAcrossTractor true

  % ------------------------
  % Optional fold marks
  % ------------------------
  /foldMarks       true
  /foldMarkGray    0.50
  /foldMarkWidth   0.8
  /foldMarkLen     0.3 inch
>> def

% ============================================================
% Drawing procedures
% ============================================================

% ------------------------------------------------------------
% Draw alternating tinted bands (aligned from top)
% ------------------------------------------------------------
/drawBands {
  /bh cfg /bandHeight get def
  /tA cfg /bandTintA get def
  /tB cfg /bandTintB get def
  /tint getBandTint def

  % Base background fill
  gsave
    tint tB setTinted
    newpath 0 0 moveto PW 0 rlineto 0 PH rlineto
    PW neg 0 rlineto closepath fill
  grestore

  % Start from top edge
  /y PH bh sub def
  /i 0 def
  {
    y 0 lt { exit } if
    gsave
      tint i 2 mod 0 eq { tA } { tB } ifelse setTinted
      newpath
        0 y moveto
        PW 0 rlineto
        0 bh rlineto
        PW neg 0 rlineto
      closepath fill
    grestore
    /y y bh sub def
    /i i 1 add def
  } loop
} bind def

% ------------------------------------------------------------
% Draw horizontal ruling (top-referenced)
% First line always thin
% ------------------------------------------------------------
/drawRuling {

  /cl cfg /contentLeft get def
  /cr cfg /contentRight get def
  /ct cfg /contentTop get def
  /cb cfg /contentBottom get def
  /tb cfg /tractorBand get def

  /x1 cl tb add def
  /x2 PW cr sub tb sub def
  /pitch cfg /linePitch get def

  /yTop ct def
  /k 1 def

  {
    yTop PH cb sub gt { exit } if
    /isMajor k cfg /majorEvery get mod 0 eq def
    /yPS PH yTop sub def

    gsave
      isMajor {
        cfg /majorLineGray get gray
        cfg /majorLineWidth get setlinewidth
      }{
        cfg /thinLineGray get gray
        cfg /thinLineWidth get setlinewidth
      } ifelse
      x1 yPS x2 yPS line
    grestore

    /yTop yTop pitch add def
    /k k 1 add def
  } loop
} bind def

% ------------------------------------------------------------
% Draw horizontal micro-cut lines
% ------------------------------------------------------------
/drawMicroCuts {
  cfg /microCut get not { exit } if

  /every cfg /foldEvery get def
  cfg /microCutAcrossTractor get
    { /x1 0 def /x2 PW def }
    {
      /cl cfg /contentLeft get def
      /cr cfg /contentRight get def
      /tb cfg /tractorBand get def
      /x1 cl tb add def
      /x2 PW cr sub tb sub def
    } ifelse

  /yTop 0 def
  {
    yTop PH gt { exit } if
    /yPS PH yTop sub def

    gsave
      cfg /microCutGray get gray
      cfg /microCutWidth get setlinewidth
      cfg /microCutDash get 0 setdash
      x1 yPS x2 yPS line
      [] 0 setdash
    grestore

    /yTop yTop every add def
  } loop
} bind def

% ------------------------------------------------------------
% Draw vertical micro-perforation lines (edge-based)
% ------------------------------------------------------------
/drawMicroPerfs {
  cfg /microPerfs get not { exit } if

  /tb cfg /tractorBand get def
  /outer cfg /microPerfOuterInset get def
  /inner cfg /microPerfInnerInset get def

  /xL_outer outer def
  /xL_inner tb inner sub def
  /xR_outer PW outer sub def
  /xR_inner PW tb sub inner add def

  gsave
    cfg /microPerfGray get gray
    cfg /microPerfWidth get setlinewidth
    cfg /microPerfDash get 0 setdash

    xL_outer 0 xL_outer PH line
    xL_inner 0 xL_inner PH line
    xR_inner 0 xR_inner PH line
    xR_outer 0 xR_outer PH line

    [] 0 setdash
  grestore
} bind def

% ------------------------------------------------------------
% Draw tractor feed holes
% ------------------------------------------------------------
/drawTractorHoles {
  /inset cfg /holeInset get def
  /r cfg /holeRadius get def
  /step 72 cfg /holesPerInch get div def

  /xL inset def
  /xR PW inset sub def

  /y r def
  /yMax PH r sub def

  {
    y yMax gt { exit } if

    gsave
      1 gray
      xL y r fillCircle
      xR y r fillCircle
    grestore

    gsave
      cfg /holeGray get gray
      0.4 setlinewidth
      newpath xL y r 0 360 arc stroke
      newpath xR y r 0 360 arc stroke
    grestore

    /y y step add def
  } loop
} bind def

% ------------------------------------------------------------
% Draw optional fold marks
% ------------------------------------------------------------
/drawFoldMarks {
  cfg /foldMarks get not { exit } if

  /len cfg /foldMarkLen get def
  /every cfg /foldEvery get def
  /yTop 0 def

  gsave
    cfg /foldMarkGray get gray
    cfg /foldMarkWidth get setlinewidth
    {
      yTop PH gt { exit } if
      /yPS PH yTop sub def
      0 yPS 0 len add yPS line
      PW len sub yPS PW yPS line
      /yTop yTop every add def
    } loop
  grestore
} bind def
%%EndProlog

%%BeginSetup
% Page size must be defined in Setup for DSC-aware interpreters
/reqPW cfg /pageWidthInch get inch def
/reqPH cfg /pageHeightInch get inch def
<< /PageSize [reqPW reqPH] >> setpagedevice
%%EndSetup

%%Page: 1 1
%%BeginPageSetup
initgraphics
erasepage

% Align origin with actual device clipping area
clippath pathbbox
/ury exch def /urx exch def
/lly exch def /llx exch def
llx neg lly neg translate

/PW urx llx sub def
/PH ury lly sub def

% Explicit clipping region
newpath 0 0 moveto PW 0 rlineto 0 PH rlineto
PW neg 0 rlineto closepath clip newpath
%%EndPageSetup

% ============================================================
% MAIN DRAWING SEQUENCE
% ============================================================
gsave
  drawBands
  drawRuling
  drawMicroCuts
  drawMicroPerfs
  drawTractorHoles
  drawFoldMarks
grestore

showpage
%%EOF
