%!PS-Adobe-3.0
%%Title: Dot-Matrix 8x8 Vertical Font (A-Z a-z) + Text Rendering
%%Pages: 1
%%BoundingBox: 0 0 595 842
%%EndComments

initgraphics

% =========================================================
% Global Parameters
% =========================================================
/dotRadius  1 def        % point radix
/dotGray    0.15 def     % point gray level

% Steps center to center (column & row)
/dotStepX   2 def        % distance between columns (centers)
/dotStepY   2 def        % distance between vertical points (centers)

% Distance between letters and lines (additional in points)
/charGapX   0 def
/lineGapY   1 def

% =========================================================
% Routine: fillCircle
% x y -> -
% =========================================================
/fillCircle {
  /y exch def
  /x exch def
  gsave
    dotGray setgray
    newpath x y dotRadius 0 360 arc closepath fill
  grestore
} def

% =========================================================
% Routine: drawByteBits (COLUMNA)
% byte xStart yStart -> -
% bit0 = up pixel (yStart), bit7 = low pixel
% =========================================================
/drawByteBits {
  10 dict begin
    /yStart exch def
    /xStart exch def
    /b exch def

    0 1 7 {
      /i exch def
      b 1 i bitshift and 0 ne {
        xStart
        yStart i dotStepY mul sub
        fillCircle
      } if
    } for
  end
} def

% =========================================================
% Routine: drawByteArrayColumns
% arr n xBase yTop -> -
% Draw n bytes like n joined columns.
% =========================================================
/drawByteArrayColumns {
  10 dict begin
    /yTop exch def
    /xBase exch def
    /n exch def
    /arr exch def

    0 1 n 1 sub {
      /k exch def
      arr k get
      xBase k dotStepX mul add
      yTop
      drawByteBits
    } for
  end
} def

% =========================================================
% Font: letras A-Z y a-z (8 bytes por carácter, VERTICAL)
% byte0..byte7 = columsn left->right, bits 0..7 = up->down
% glifo "Unknown" included for not defined chars
% =========================================================
% =========================================================
% Font8x8ByCode: ASCII(int) -> [8 bytes]   (8x8, columnas, bit0 arriba)
% =========================================================
/Font8x8ByCode 256 dict def
/putGlyph { Font8x8ByCode 3 1 roll put } bind def

% Unknown (lo guardo en 0 para fallback explícito)
0 [16#00 16#C3 16#A5 16#99 16#99 16#A5 16#C3 16#00] putGlyph
% -------------------------------------------------
